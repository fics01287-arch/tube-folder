{
  "manifest_version": 3,
  "name": "튜브폴더 (TubeFolder)",
  "version": "1.5.0",
  "description": "유튜브 동영상·뮤직을 내 컴퓨터 탐색기처럼 무제한 폴더로 정리합니다.",
  "permissions": ["storage", "contextMenus", "tabs", "unlimitedStorage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://music.youtube.com/*",
    "https://youtu.be/*",
    "https://noembed.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "튜브폴더 열기",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
